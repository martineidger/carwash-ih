				$("#menu-top").removeClass("on");
			} else {
				$("#menu-top").addClass("on");
				if ($("header div.address").hasClass("on")) {
					$("header div.address").removeClass("on");
				}
			}
		} else if($(e.target).parent().hasClass('address') || $(e.target).hasClass('address')) {
			if ($("header div.address").hasClass("on")) {
				$("header div.address").removeClass("on");
			} else {
				$("header div.address").addClass("on");
				if ($("#menu-top").hasClass("on")) {
					$("#menu-top").removeClass("on");
				}
			}
		}
	};
	
	$("body").on("click", ".price-btn", function (e) {
		e.preventDefault();
