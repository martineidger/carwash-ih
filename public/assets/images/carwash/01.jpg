	});
		$.ajax({
		url:"/_js/jquery.waypoints.min.js",
		dataType:"script",
		cache:true,
		success:function(){
			$("footer").waypoint(function(direction){
				if(direction==="down"){
						$("div.address").addClass("hide")
					}else if(direction==="up"){
						$("div.address").removeClass("hide")
					}
				},
			{ offset:"80%" });	
		}
	});	
});
