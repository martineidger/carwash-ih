ute;bottom:0;left:50%;transform:translate(-50%,7vw);width:38vw;text-align:center;font-family:"druk-medium",Arial,Helvetica,sans-serif;font-size:3.5rem;height:38vw;background:rgba(255,255,255,.2);border-radius:50%;padding:8vw 0;transition:border-radius 1s;-webkit-backdrop-filter: blur(8px);backdrop-filter:blur(8px);}section.submenu li .sub-block h3{font-family:"druk-medium",Arial,Helvetica,sans-serif;font-size:3.5rem;color:#000;text-align:left;margin-bottom:3vw;}section.submenu li .sub-block span{position:absolute;display:block;width:38vw;height:100%;left:50%;transform:translate(-50%, 0%);bottom:0;padding:8vw 5vw;font-family:"montserrat-regular",Arial,Helvetica,sans-serif;font-size:1rem;line-height:1.8rem;text-align:justify;color:#000;opacity:0;transition:opacity .4s;background:#fff}section.submenu li .sub-block:hover{border-radius:0}section.submenu li .sub-block:hover span{opacity:1}section.more{z-index:1;padding:6vw 15vw 10vw 15vw;position:relative}section.more h2{font-family:"druk-medium",Arial,Helvetica,sans-serif;font-size:2.2rem;line-height:3.2rem;margin-bottom:5vw}section.more .more-wrapper{text-align:justify;position:relative;z-index:4}section.more .more-wrapper a{display:inline-block;padding:2.2rem 4rem;margin-bottom:5vw;position:relative;z-index:1}section.more .more-wrapper a:hover{z-index:3}section.more .more-wrapper a:before{background:#111111}section.more .more-wrapper a:nth-child(3){margin-left:20vw}section.more .more-wrapper a:nth-child(5){margin-left:7vw}#aToolTip{position:absolute;display:none;z-index:2;pointer-events:none}#aToolTip img{width:25vw;height:auto;transform:translate(-50%,50%)}#aToolTip .aToolTipContent{position:relative;margin:0;padding:0;color:#252525!important}.defaultTheme{border:0px;margin:0;padding:0;}section.price{z-index:21;padding:6vw 15vw 0 15vw;position:relative}section.price h2{font-family:"druk-medium",Arial,Helvetica,sans-serif;font-size:2.2rem;line-height:3.2rem;margin-bottom:5vw}section.price .ellipse{z-index:-2;width:60vw